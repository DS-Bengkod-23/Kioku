# ================================
# Database
# ================================
DATABASE_URL=postgresql://meetmate:meetmate@localhost:5432/meetmate

# Dipakai oleh docker-compose.yml untuk container Postgres & untuk membangun
# DATABASE_URL versi Docker (host `postgres`, bukan `localhost`). GANTI nilai
# ini (bukan cuma DATABASE_URL di atas) untuk deployment di luar localhost —
# docker-compose.yml akan menimpa DATABASE_URL secara otomatis memakai variable ini.
POSTGRES_PASSWORD=meetmate

# ================================
# Redis
# ================================
REDIS_URL=redis://:devredispass@localhost:6379

# Dipakai oleh docker-compose.yml untuk container Redis (requirepass) & untuk
# membangun REDIS_URL versi Docker (host `redis`, bukan `localhost`). GANTI nilai
# ini (bukan cuma REDIS_URL di atas) untuk deployment di luar localhost —
# docker-compose.yml akan menimpa REDIS_URL secara otomatis memakai variable ini
# kalau backend-api/celery-worker jalan lewat Docker. Tapi mode Hybrid (backend-api
# di host, lihat README) baca REDIS_URL di atas apa adanya tanpa override — makanya
# passwordnya sudah harus ikut di URL-nya dari awal.
REDIS_PASSWORD=devredispass

# ================================
# MinIO (Local Object Storage)
# ================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=meetmate-recordings
MINIO_SECURE=false

# Kredensial root container MinIO (docker-compose.yml). Di setup sederhana ini,
# MINIO_ACCESS_KEY/MINIO_SECRET_KEY di atas DIPAKAI SEBAGAI kredensial root —
# jadi kalau ganti MINIO_ROOT_USER/MINIO_ROOT_PASSWORD di sini, samakan juga
# MINIO_ACCESS_KEY/MINIO_SECRET_KEY di atas.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ================================
# Email (pilih salah satu, comment/uncomment sesuai kebutuhan)
# ================================

# --- Opsi 1: Mailhog (dev lokal — email tidak terkirim, cek di http://localhost:8025) ---
SMTP_HOST=localhost
SMTP_HOST_DOCKER=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# --- Opsi 2: Gmail (demo/presentasi — email benar-benar terkirim ke inbox) ---
# Cara buat App Password: Google Account → Security → 2-Step Verification → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_HOST_DOCKER=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=emailkamu@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_USE_TLS=true

# ================================
# Auth
# ================================
JWT_SECRET_KEY=your_super_secret_key_here
JWT_EXPIRE_MINUTES=1440
CHECKIN_TOKEN_EXPIRE_HOURS=24

# ================================
# Language Model (LLM) Provider
# ================================
# Provider aktif untuk transcribe + summary/action item extraction.
# Pilihan: 'openai' atau 'gemini'. Ganti nilai ini lalu jalankan:
#   docker compose build celery-worker && docker compose up -d celery-worker
# buat pindah provider tanpa perlu ubah kode.
LLM_PROVIDER=openai

# ================================
# OpenAI (dipakai kalau LLM_PROVIDER=openai)
# ================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_MODEL=gpt-4o-mini

# ================================
# Gemini (dipakai kalau LLM_PROVIDER=gemini)
# ================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# ================================
# File Upload
# ================================
# Catatan: kalau LLM_PROVIDER=openai, batas efektif per-file adalah 25MB (hard
# limit endpoint /v1/audio/transcriptions OpenAI) terlepas dari nilai di bawah ini.
MAX_UPLOAD_SIZE_MB=200
MAX_AUDIO_DURATION_HOURS=2
ALLOWED_AUDIO_FORMATS=mp3,mp4,wav,m4a

# ================================
# App
# ================================
APP_ENV=development
APP_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# HuggingFace Token untuk model pyannote (Diarization)
HF_TOKEN=hf_your_huggingface_token_here

# ================================
# Branding (kop surat notulen PDF)
# ================================
# Opsional — ada default-nya (ORG_NAME="UNIVERSITAS DIAN NUSWANTORO", ORG_LOGO_PATH
# kosong), jadi aplikasi tetap jalan normal kalau tidak diisi. Isi ini kalau notulen
# PDF perlu tampil dengan nama & logo institusi/organisasi yang berbeda.
ORG_NAME=Universitas Dian Nuswantoro

# Path ke file logo (PNG/JPG). PAKAI PATH RELATIF, taruh filenya di backend/assets/,
# misal ORG_LOGO_PATH=assets/logo.png (bukan /app/assets/logo.png).
# Kenapa relatif: backend-api dan celery-worker punya struktur folder beda di
# dalam image (lihat docs/DOCKER_CHANGES.md), path relatif otomatis resolve benar
# di keduanya karena working directory masing-masing sejajar dengan backend/.
# File di-bake ke image via COPY (tidak ada volume mount) — WAJIB `make build`
# ulang setelah menambah/ganti file logo, restart saja tidak cukup.
# Kalau file tidak ditemukan, PDF tetap render normal (cuma tanpa logo, teks saja).
ORG_LOGO_PATH=

